<?xml version="1.0" encoding="utf-8"?>
<!--
  LinearLayout（竖向）：
    - WebView：填充剩余空间，显示 Web 应用内容
    - BottomNavigationView：固定在底部，高度 56dp，映射核心导航功能
  splashOverlay 叠加于整个布局顶层，启动时遮盖初始化闪烁。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 主体：WebView + 底部导航栏垂直排列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 底部原生导航栏
             wrap_content 高度：BottomNavigation 内容高度 + 底部 padding（导航条高度）自动撑开，
             避免固定 56dp 时 updatePadding(bottom) 把图标和文字挤在一起导致重叠。 -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:background="@color/bottom_nav_background"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/bottom_nav_colors"
            app:itemTextColor="@color/bottom_nav_colors"
            app:itemTextAppearanceActive="@style/BottomNavTextActive"
            app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
            app:labelVisibilityMode="labeled"
            app:elevation="8dp" />

    </LinearLayout>

    <!-- 启动遮罩：全屏启动画面，WebView 就绪后淡出 -->
    <include
        android:id="@+id/splashOverlay"
        layout="@layout/splash_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>

