<?xml version="1.0" encoding="utf-8"?>
<!--
  全屏启动画面布局（v2）
  · Logo 专用 drawable（splash_logo.xml），无 Adaptive Icon 留白，104dp 即视觉尺寸
  · 进度条紧贴副标题下方（原分割线位置）
  · 终端标语行保留，无"正在启动"文字
  · 所有强调色通过 @color/ 引用，深/浅模式自动切换
  · 关键视图添加 ID，供 MainActivity 在运行时注入主题色

  ┌─────────────────────────┐
  │ [L]               [R]   │  ← 角落装饰
  │                         │
  │       [Octocat]          │  ← 120dp logo，无光圈
  │      GitHub 管理器       │
  │   随时随地，高效管理     │
  │   ══════════════════     │  ← 进度条（accent 色）
  │   $ git clone your_future▌ │
  │                         │
  │ [L]               [R]   │  ← 角落装饰
  └─────────────────────────┘
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <!-- ── 左上角装饰 ── -->
    <LinearLayout
        android:id="@+id/splashCornerTL"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_margin="28dp"
        android:orientation="vertical">
        <View
            android:layout_width="40dp"
            android:layout_height="1.5dp"
            android:background="@color/splash_corner_line" />
        <View
            android:layout_width="1.5dp"
            android:layout_height="40dp"
            android:background="@color/splash_corner_line" />
    </LinearLayout>

    <!-- ── 右上角装饰 ── -->
    <LinearLayout
        android:id="@+id/splashCornerTR"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="28dp"
        android:orientation="vertical">
        <View
            android:layout_width="40dp"
            android:layout_height="1.5dp"
            android:layout_gravity="end"
            android:background="@color/splash_corner_line" />
        <View
            android:layout_width="1.5dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:background="@color/splash_corner_line" />
    </LinearLayout>

    <!-- ── 左下角装饰 ── -->
    <LinearLayout
        android:id="@+id/splashCornerBL"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="28dp"
        android:layout_marginBottom="52dp"
        android:orientation="vertical"
        android:gravity="bottom">
        <View
            android:layout_width="1.5dp"
            android:layout_height="40dp"
            android:background="@color/splash_corner_line" />
        <View
            android:layout_width="40dp"
            android:layout_height="1.5dp"
            android:background="@color/splash_corner_line" />
    </LinearLayout>

    <!-- ── 右下角装饰 ── -->
    <LinearLayout
        android:id="@+id/splashCornerBR"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="52dp"
        android:orientation="vertical"
        android:gravity="bottom">
        <View
            android:layout_width="1.5dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:background="@color/splash_corner_line" />
        <View
            android:layout_width="40dp"
            android:layout_height="1.5dp"
            android:background="@color/splash_corner_line" />
    </LinearLayout>

    <!-- ── 中央主内容区（整体上移，使"GitHub 管理器"文字视觉居中） ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Octocat Logo（启动画面专用，无 Adaptive Icon 留白，88dp 即为真实视觉尺寸） -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@drawable/splash_logo"
            android:tint="@color/splash_icon_tint"
            android:scaleType="fitCenter"
            android:contentDescription="GitHub Logo" />

        <!-- 标题：GitHub 管理器 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="GitHub 管理器"
            android:textColor="@color/splash_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-medium" />

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="随时随地，高效管理你的开发世界"
            android:textColor="@color/splash_subtitle"
            android:textSize="13sp"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif" />

        <!-- 进度条（原分割线位置，accent 色，由 MainActivity 注入主题色） -->
        <ProgressBar
            android:id="@+id/splashProgress"
            android:layout_width="200dp"
            android:layout_height="2dp"
            android:layout_marginTop="20dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:indeterminateDuration="18000"
            android:indeterminateTint="@color/splash_accent"
            android:progressTint="@color/splash_accent"
            android:indeterminateTintMode="src_in" />

        <!-- 终端风格标语行 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 终端提示符 $ -->
            <TextView
                android:id="@+id/splashPrompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ "
                android:textColor="@color/splash_prompt"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- 命令文字（打字动画目标，初始为空，由 MainActivity 逐字填充） -->
            <TextView
                android:id="@+id/splashTerminalText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/splash_terminal"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- 光标块 -->
            <View
                android:id="@+id/splashCursor"
                android:layout_width="8dp"
                android:layout_height="14dp"
                android:layout_marginStart="2dp"
                android:background="@color/splash_cursor" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>


