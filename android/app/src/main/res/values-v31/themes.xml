<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+（API 31）系统启动画面主题（浅色模式）。
  API 35 强制边到边，移除 statusBarColor / navigationBarColor（已废弃）。
  系统栏颜色外观由 WindowInsetsControllerCompat 在运行时控制。
-->
<resources>
    <style name="Theme.GitHubManager" parent="Theme.Material3.Light.NoActionBar">
        <!-- 系统启动画面背景色（浅色模式）：与自定义启动页背景色完全一致，无缝衔接 -->
        <!-- 不设置 windowSplashScreenAnimatedIcon，避免在自定义启动页前出现额外的系统图标层 -->
        <item name="android:windowSplashScreenBackground">@color/splash_bg_solid</item>
        <item name="android:windowBackground">@color/splash_bg_solid</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="colorPrimary">#7c3aed</item>
        <item name="colorPrimaryVariant">#6d28d9</item>
        <item name="colorOnPrimary">#ffffff</item>
        <!-- M3 Active Indicator 填充色（API 31+ 浅色模式） -->
        <item name="colorSecondaryContainer">#EDE9FE</item>
        <item name="colorOnSecondaryContainer">#5B21B6</item>
    </style>
</resources>
